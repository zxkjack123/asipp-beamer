\ProvidesPackage{beamercolorthemeASIPPWhite}[2026/04/29 ASIPP white color theme, aligned to ai-ppt asipp_template.pptx]

% Color palette extracted from ai-ppt/templates/asipp_template.pptx (theme1.xml).
% These are the canonical institute colors used by current ASIPP report templates.

\mode<presentation>

% --- Primary palette ---
\definecolor{ASIPPNavy}{HTML}{0F1423}     % dk2: titles, body text
\definecolor{ASIPPBlue}{HTML}{6096E6}     % accent1: title rule, bullets, block titles
\definecolor{ASIPPBlueDark}{HTML}{0563C1} % hyperlink / strong accent
\definecolor{ASIPPCyan}{HTML}{58B6E5}     % accent2
\definecolor{ASIPPGreen}{HTML}{56CA95}    % accent3 (example blocks)
\definecolor{ASIPPAmber}{HTML}{FFBA55}    % accent4 (secondary highlight)
\definecolor{ASIPPSalmon}{HTML}{F18870}   % accent5
\definecolor{ASIPPRed}{HTML}{EC5F74}      % accent6 (alert text)

% --- Compatibility aliases (legacy theme used these) ---
\definecolor{ASIPPGold}{HTML}{FFBA55}
\definecolor{EmphColor}{HTML}{EC5F74}
\definecolor{HighlightBackground}{HTML}{FFBA55}
\definecolor{KeywordColor}{HTML}{0F1423}

% --- Backgrounds and text ---
\setbeamercolor*{normal text}{fg=ASIPPNavy,bg=white}
\setbeamercolor{background canvas}{bg=white}
\setbeamercolor*{alerted text}{fg=ASIPPRed}
\setbeamercolor*{example text}{fg=ASIPPGreen}
\setbeamercolor{structure}{fg=ASIPPBlue}

% --- Title-related ---
\setbeamercolor{title}{fg=ASIPPNavy}
\setbeamercolor{subtitle}{fg=ASIPPBlueDark}
\setbeamercolor{author}{fg=ASIPPNavy}
\setbeamercolor{institute}{fg=ASIPPNavy!70!white}
\setbeamercolor{date}{fg=ASIPPNavy!70!white}
\setbeamercolor{frametitle}{fg=ASIPPNavy,bg=white}
\setbeamercolor{framesubtitle}{fg=ASIPPBlueDark}
\setbeamercolor{section text}{fg=ASIPPBlueDark}
\setbeamercolor{titlelike}{fg=ASIPPNavy}

% --- Lists ---
\setbeamercolor{itemize item}{fg=ASIPPBlue}
\setbeamercolor{itemize subitem}{fg=ASIPPAmber}
\setbeamercolor{itemize subsubitem}{fg=ASIPPBlueDark}
\setbeamercolor{enumerate item}{fg=ASIPPBlue}
\setbeamercolor{enumerate subitem}{fg=ASIPPAmber}
\setbeamercolor{description item}{fg=ASIPPBlueDark}
\setbeamercolor{item projected}{fg=white,bg=ASIPPBlue}

% --- Blocks: blue title bar on a soft tinted body ---
\setbeamercolor{block title}{fg=white,bg=ASIPPBlue}
\setbeamercolor{block body}{fg=ASIPPNavy,bg=ASIPPBlue!8!white}
\setbeamercolor{block title alerted}{fg=white,bg=ASIPPRed}
\setbeamercolor{block body alerted}{fg=ASIPPNavy,bg=ASIPPRed!8!white}
\setbeamercolor{block title example}{fg=white,bg=ASIPPGreen}
\setbeamercolor{block body example}{fg=ASIPPNavy,bg=ASIPPGreen!8!white}

% --- Palette (used by sidebar / headline templates) ---
\setbeamercolor{palette primary}{fg=ASIPPNavy,bg=white}
\setbeamercolor{palette secondary}{fg=white,bg=ASIPPBlue}
\setbeamercolor{palette tertiary}{fg=white,bg=ASIPPBlueDark}
\setbeamercolor{palette quaternary}{fg=white,bg=ASIPPNavy}

% --- Footline / page numbers ---
\setbeamercolor{page number in head/foot}{fg=ASIPPNavy!70!white}
\setbeamercolor{title in head/foot}{fg=ASIPPNavy!70!white}
\setbeamercolor{author in head/foot}{fg=ASIPPNavy!70!white}

% --- Separation rules ---
\setbeamercolor*{separation line}{bg=ASIPPBlue}
\setbeamercolor*{fine separation line}{bg=ASIPPBlue!50!white}

\mode<all>
