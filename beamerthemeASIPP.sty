\ProvidesPackage{beamerthemeASIPP}[2026/04/29 ASIPP beamer theme, aligned to ai-ppt PPTX master]

% =====================================================================
% ASIPP beamer theme, redesigned in 2026-04 to align with the ai-ppt
% asipp_template.pptx master used by the institute's PPTX deliverables.
%
% Visual identity replicated from the PPTX master:
%   * 16:9 white-background slides (use [aspectratio=169])
%   * ASIPP "CQ" logo at top-left of every content frame
%   * Bold dark-navy title, thin blue rule underneath
%   * Right-aligned footer "第 N / M 页" (or "Page N of M")
%   * Section divider page with large centered section title
%   * Dedicated thank-you/closing page
%
% Usage (recommended):
%   \documentclass[aspectratio=169]{ctexbeamer}    % CJK
%       % --- or for English-only decks ---
%   % \documentclass[aspectratio=169]{beamer}
%   \usetheme{ASIPP}                               % white variant (default)
%       % --- or for the dark variant ---
%   % \usetheme[dark]{ASIPP}
%
% Required asset (place in working directory or TeX search path):
%   asipp_logo.pdf                                 % institute logo
%
% Provided commands beyond the standard beamer set:
%   \asippsectionpage      % renders a section divider slide automatically at \section
%   \thankspage{<message>} % renders a closing slide with the given message
%   \asippfootenglish      % switch footer to "Page N of M"
%   \asippfootchinese      % switch footer back to "第 N/M 页" (default)
% =====================================================================

\RequirePackage{tabularx}
\RequirePackage{tikz}

% --- Options -------------------------------------------------------------
\newif\ifbeamer@nav            \beamer@navfalse
\DeclareOptionBeamer{nav}{\beamer@navtrue}

\newif\ifbeamer@asippdark      \beamer@asippdarkfalse
\DeclareOptionBeamer{dark}{\beamer@asippdarktrue}
\DeclareOptionBeamer{white}{\beamer@asippdarkfalse}  % accepted for backward compat

\newif\ifbeamer@nologo         \beamer@nologofalse
\DeclareOptionBeamer{nologo}{\beamer@nologotrue}

\newif\ifbeamer@compactlogo    \beamer@compactlogofalse
\DeclareOptionBeamer{compactlogo}{\beamer@compactlogotrue}

\newif\ifbeamer@sections       \beamer@sectionsfalse
\DeclareOptionBeamer{sections}{\beamer@sectionstrue}

\newif\ifbeamer@noslidenumbers \beamer@noslidenumbersfalse
\DeclareOptionBeamer{noslidenumbers}{\beamer@noslidenumberstrue}

\newif\ifbeamer@autoseppage    \beamer@autoseppagetrue
\DeclareOptionBeamer{nosectionpage}{\beamer@autoseppagefalse}

\ProcessOptionsBeamer

\mode<presentation>

% --- Color theme ---------------------------------------------------------
\ifbeamer@asippdark
  \usecolortheme{ASIPP}
\else
  \usecolortheme{ASIPPWhite}
\fi

% --- Inner theme: rounded blocks, circle bullets -------------------------
\useinnertheme{circles}
\setbeamertemplate{blocks}[rounded][shadow=false]

% --- Outer theme (frametitle bar, footline) ------------------------------
\useoutertheme{subtle}

% --- Logo ---------------------------------------------------------------
% The corner logo for content frames is drawn by an absolute TikZ overlay
% in beamerouterthemesubtle.sty (see \asippcornerlogo). \logo{} is kept
% empty so legacy templates referring to \insertlogo do not error.
\logo{}
\ifbeamer@compactlogo
  \titlegraphic{\includegraphics[height=1.5cm]{asipp_logo.pdf}}
\else
  \titlegraphic{\includegraphics[height=2.4cm]{asipp_logo.pdf}}
\fi

% --- Fonts --------------------------------------------------------------
\setbeamerfont{frametitle}{size=\LARGE,series=\bfseries}
\setbeamerfont{framesubtitle}{size=\normalsize,shape=\itshape}
\setbeamerfont{title}{size=\LARGE,series=\bfseries}
\setbeamerfont{subtitle}{size=\large}
\setbeamerfont{author}{size=\normalsize}
\setbeamerfont{institute}{size=\small}
\setbeamerfont{date}{size=\small}
\setbeamerfont{block title}{size=\normalsize,series=\bfseries}
\setbeamerfont{page number in head/foot}{size=\scriptsize}
\setbeamerfont{section title}{size=\Huge,series=\bfseries}

% --- Title page template (PPTX-aligned) ---------------------------------
% Layout: logo top-center, title centered, subtitle, then
% author / institute / date stacked below, separator rule above date.
\defbeamertemplate*{title page}{asipp pptx}{%
  \begin{centering}%
    \vfill
    \ifbeamer@nologo\else
      {\inserttitlegraphic\par}%
      \vskip1.0em%
    \fi
    {\usebeamerfont{title}\usebeamercolor[fg]{title}\inserttitle\par}%
    \ifx\insertsubtitle\@empty\else
      \vskip0.5em%
      {\usebeamerfont{subtitle}\usebeamercolor[fg]{subtitle}\insertsubtitle\par}%
    \fi
    \vskip1.5em%
    {\color{ASIPPBlue}\rule{0.4\paperwidth}{0.6pt}}\par%
    \vskip1.0em%
    {\usebeamerfont{author}\usebeamercolor[fg]{author}\insertauthor\par}%
    \vskip0.3em%
    {\usebeamerfont{institute}\usebeamercolor[fg]{institute}\insertinstitute\par}%
    \vskip0.3em%
    {\usebeamerfont{date}\usebeamercolor[fg]{date}\insertdate\par}%
    \vfill
  \end{centering}%
}

% --- Section page template (mirrors PPTX layout 4 "1_节标题") -----------
% Renders a divider slide showing the current section name centred on the
% canvas with a wide blue rule above and below.
\defbeamertemplate*{section page}{asipp pptx}{%
  \begin{centering}%
    \vfill
    {\color{ASIPPBlue}\rule{0.55\paperwidth}{1.2pt}}\par
    \vskip0.8em%
    {\usebeamerfont{section title}\usebeamercolor[fg]{titlelike}\insertsection\par}%
    \vskip0.6em%
    {\color{ASIPPBlue}\rule{0.25\paperwidth}{0.6pt}}\par
    \vfill
  \end{centering}%
}

\newcommand{\asippsectionpage}{\frame[plain,noframenumbering]{\sectionpage}}

% Optional: insert a section divider automatically at the start of every
% \section (suppress with the [nosectionpage] theme option).
\ifbeamer@autoseppage
  \AtBeginSection[]{\asippsectionpage}
\fi

% --- Closing / "Thank you" page -----------------------------------------
% Usage: \thankspage{Thank you for your attention!}
%        \thankspage[Q\&A]{谢谢！}      % optional subtitle in []
\newcommand{\thankspage}[2][]{%
  {\setbeamertemplate{footline}{}%
   \begin{frame}[plain,noframenumbering]
     \vfill
     \begin{centering}
       \ifbeamer@nologo\else
         \includegraphics[height=1.6cm]{asipp_logo.pdf}\par
         \vskip1.0em%
       \fi
       {\usebeamerfont{title}\usebeamercolor[fg]{title}#2\par}%
       \vskip0.6em%
       {\color{ASIPPBlue}\rule{0.3\paperwidth}{0.6pt}}\par
       \ifx\\#1\\\else
         \vskip0.8em%
         {\usebeamerfont{subtitle}\usebeamercolor[fg]{subtitle}#1\par}%
       \fi
     \end{centering}
     \vfill
   \end{frame}}%
}

% --- Disable navigation symbols unless explicitly requested -------------
\ifbeamer@nav\else
  \setbeamertemplate{navigation symbols}{}
\fi

% --- Misc tweaks --------------------------------------------------------
\setbeamertemplate{caption}[numbered]
\setbeamercolor{caption name}{fg=ASIPPBlueDark}
\setbeamertemplate{bibliography item}[text]

\mode<all>
