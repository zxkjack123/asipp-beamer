\ProvidesPackage{beamercolorthemeASIPP}[2026/04/29 ASIPP dark color theme]

% Dark variant. The PPTX master uses a white background; this dark theme is
% provided for screen-only / dim-room presentations and reuses the same accent
% palette as the white theme so the two variants stay visually consistent.

\mode<presentation>

\beamersetaveragebackground{black}

% --- Primary palette (shared with the White theme) ---
\definecolor{ASIPPNavy}{HTML}{0F1423}
\definecolor{ASIPPBlue}{HTML}{6096E6}
\definecolor{ASIPPBlueDark}{HTML}{0563C1}
\definecolor{ASIPPCyan}{HTML}{58B6E5}
\definecolor{ASIPPGreen}{HTML}{56CA95}
\definecolor{ASIPPAmber}{HTML}{FFBA55}
\definecolor{ASIPPSalmon}{HTML}{F18870}
\definecolor{ASIPPRed}{HTML}{EC5F74}

% Legacy aliases
\definecolor{ASIPPGold}{HTML}{FFBA55}
\definecolor{EmphColor}{HTML}{EC5F74}
\definecolor{HighlightBackground}{HTML}{FFBA55}
\definecolor{KeywordColor}{HTML}{6096E6}

% --- Backgrounds and text ---
\setbeamercolor*{normal text}{fg=white,bg=ASIPPNavy}
\setbeamercolor{background canvas}{bg=ASIPPNavy}
\setbeamercolor*{alerted text}{fg=ASIPPAmber}
\setbeamercolor*{example text}{fg=ASIPPGreen}
\setbeamercolor{structure}{fg=ASIPPBlue}

% --- Title-related ---
\setbeamercolor{title}{fg=white}
\setbeamercolor{subtitle}{fg=ASIPPBlue}
\setbeamercolor{author}{fg=white}
\setbeamercolor{institute}{fg=white!80!gray}
\setbeamercolor{date}{fg=white!80!gray}
\setbeamercolor{frametitle}{fg=white,bg=ASIPPNavy}
\setbeamercolor{framesubtitle}{fg=ASIPPBlue}
\setbeamercolor{section text}{fg=ASIPPBlue}
\setbeamercolor{titlelike}{fg=white}

% --- Lists ---
\setbeamercolor{itemize item}{fg=ASIPPBlue}
\setbeamercolor{itemize subitem}{fg=ASIPPAmber}
\setbeamercolor{itemize subsubitem}{fg=ASIPPCyan}
\setbeamercolor{enumerate item}{fg=ASIPPBlue}
\setbeamercolor{enumerate subitem}{fg=ASIPPAmber}
\setbeamercolor{description item}{fg=ASIPPBlue}
\setbeamercolor{item projected}{fg=ASIPPNavy,bg=ASIPPBlue}

% --- Blocks ---
\setbeamercolor{block title}{fg=ASIPPNavy,bg=ASIPPBlue}
\setbeamercolor{block body}{fg=white,bg=ASIPPNavy!85!white}
\setbeamercolor{block title alerted}{fg=white,bg=ASIPPRed}
\setbeamercolor{block body alerted}{fg=white,bg=ASIPPNavy!85!white}
\setbeamercolor{block title example}{fg=ASIPPNavy,bg=ASIPPGreen}
\setbeamercolor{block body example}{fg=white,bg=ASIPPNavy!85!white}

% --- Palette ---
\setbeamercolor{palette primary}{fg=white,bg=ASIPPNavy}
\setbeamercolor{palette secondary}{fg=ASIPPNavy,bg=ASIPPBlue}
\setbeamercolor{palette tertiary}{fg=white,bg=ASIPPBlueDark}
\setbeamercolor{palette quaternary}{fg=white,bg=ASIPPNavy}

% --- Footline ---
\setbeamercolor{page number in head/foot}{fg=white!80!gray}
\setbeamercolor{title in head/foot}{fg=white!80!gray}
\setbeamercolor{author in head/foot}{fg=white!80!gray}

% --- Separation rules ---
\setbeamercolor*{separation line}{bg=ASIPPBlue}
\setbeamercolor*{fine separation line}{bg=ASIPPBlue!50!white}

\mode<all>
